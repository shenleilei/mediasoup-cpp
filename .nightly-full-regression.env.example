# Copy this file to .nightly-full-regression.env and edit it for the local machine.
#
# MAIL_TO defaults to `git config user.email` when omitted, but setting it
# explicitly is recommended for the nightly job.

MAIL_TO=your-email@example.com
MAIL_FROM=your-email@example.com

# Use MAIL_TRANSPORT=auto to prefer SMTP when SMTP_HOST is set, otherwise fall
# back to local mailx if available.
MAIL_TRANSPORT=auto
MAIL_SUBJECT_PREFIX=[mediasoup-cpp nightly]

# SMTP is optional when local mailx delivery already works.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1
SMTP_USE_SSL=0
SMTP_TIMEOUT_SECONDS=30

# The nightly wrapper preserves a per-run log directory and also refreshes this
# latest-log copy for quick inspection.
NIGHTLY_ARTIFACT_ROOT=artifacts/nightly-full-regression
NIGHTLY_MAX_BACKUP_RUNS=100
NIGHTLY_LATEST_LOG_PATH=/var/log/run_all_tests.log
NIGHTLY_GIT_COMMIT_DOCS=1

# Optional attachment override. Comma-separated repo-relative paths.
# ATTACH_MD_PATHS=docs/full-regression-test-results.md,docs/uplink-qos-case-results.md

# Optional extra args forwarded to scripts/run_all_tests.sh.
# RUN_ALL_TESTS_ARGS=--skip-build
