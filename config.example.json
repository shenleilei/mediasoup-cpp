{
  "environment": "production",
  "port": 3000,
  "workers": 2,
  "workerBin": "/opt/mediasoup-cpp/mediasoup-worker",
  "listenIp": "0.0.0.0",
  "announcedIp": "YOUR_PUBLIC_IP",
  "redisHost": "127.0.0.1",
  "redisPort": 6379,
  "nodeId": "sfu-prod-01:3000",
  "nodeAddress": "wss://sfu.example.com/ws",
  "recordDir": "/var/lib/mediasoup-cpp/recordings",
  "logFile": "/var/log/mediasoup-sfu.log",
  "pidFile": "/var/run/mediasoup-sfu.pid",
  "wsAuthToken": "",
  "recordingsToken": "",
  "maxWsConnectionsPerIp": 30,
  "maxRequestsPerIpPerWindow": 300,
  "requestWindowSec": 60,
  "nodaemon": false
}
